---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const achievements = await getCollection("achievements");

// Sort by publish date (newest first)
const sorted = achievements
    .filter((a) => !a.id.startsWith("_")) // Exclude templates
    .sort((a, b) => {
        const dateA = a.data.publishDate
            ? new Date(a.data.publishDate).getTime()
            : 0;
        const dateB = b.data.publishDate
            ? new Date(b.data.publishDate).getTime()
            : 0;
        return dateB - dateA;
    });

const seoTitle = "الإنجازات | سعيد بران";
const seoDescription =
    "سجل الإنجازات والشهادات والتحديات التقنية في مسيرة سعيد بران في الأمن السيبراني.";
---

<Layout
    title={seoTitle}
    description={seoDescription}
    keywords={["إنجازات", "شهادات", "Hall of Fame", "Cybersecurity Achievements"]}
>
    <div class="space-y-10 md:space-y-16 pb-20">
        {/* Page Header */}
        <header class="relative py-10">
            <div
                class="absolute inset-0 bg-gradient-to-l from-cyber-pink/5 to-transparent rounded-[3rem] -z-10 blur-2xl"
            >
            </div>
            <div class="space-y-6 relative z-10">
                <div class="flex items-center gap-3">
                    <div
                        class="h-[2px] w-12 bg-gradient-to-r from-cyber-pink to-transparent"
                    >
                    </div>
                    <span
                    class="text-[9px] md:text-[10px] text-cyber-pink font-mono tracking-[0.25em] md:tracking-[0.4em] uppercase font-bold animate-pulse"
                        >Hall_of_Fame_v2.0</span
                    >
                </div>
                <h1
                    class="text-3xl sm:text-5xl md:text-7xl font-black tracking-tighter text-white leading-none"
                >
                    <span class="lang-ar block">الأنجازات</span>
                    <span
                        class="lang-en text-3xl text-zinc-600 block mt-2 opacity-50 uppercase"
                        >Achievements_Record</span
                    >
                </h1>
                <p
                    class="text-zinc-400 max-w-2xl font-mono text-sm leading-relaxed border-r-2 border-cyber-pink/30 pr-6 mr-2"
                >
                    <span class="lang-ar"
                        >استعراض حي لأبرز النجاحات والتحديات التي تم تجاوزها
                        بنجاح في مجالات التقنية والأمن السيبراني.</span
                    >
                    <span class="lang-en"
                        >A live showcase of major successes and challenges
                        successfully overcome in technology and cybersecurity.</span
                    >
                </p>
            </div>

            {/* Decorative Trophy Icon */}
            <div
                class="absolute top-0 left-0 hidden lg:flex flex-col items-center"
            >
                <div
                    class="w-[1px] h-20 bg-gradient-to-b from-transparent via-white/10 to-transparent"
                >
                </div>
                <div
                    class="p-4 rounded-full bg-zinc-950 border border-white/5 shadow-2xl shadow-cyber-pink/5"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="text-cyber-pink animate-spin-slow"
                        ><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path
                            d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path
                            d="M4 22h16"></path><path
                            d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"
                        ></path><path
                            d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"
                        ></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
                    </svg>
                </div>
            </div>
        </header>

        {/* Achievements Grid */}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-10">
            {
                sorted.map((item) => (
                    <a
                        href={`/achievements/${item.slug}`}
                        class="group relative flex flex-col rounded-3xl md:rounded-[3rem] bg-zinc-900/20 border border-white/5 backdrop-blur-3xl overflow-hidden hover:border-cyber-pink/40 hover:bg-zinc-900/40 transition-all duration-700 text-right w-full h-full shadow-2xl hover:shadow-cyber-pink/10"
                    >
                        {/* Animated Glow on Hover */}
                        <div class="absolute inset-0 bg-gradient-to-br from-cyber-pink/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700" />

                        {/* Image Header */}
                        <div class="relative h-52 md:h-60 overflow-hidden">
                            {item.data.image ? (
                                <img
                                    src={item.data.image}
                                    alt={item.data.title}
                                    loading="lazy"
                                    decoding="async"
                                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 group-hover:rotate-1"
                                />
                            ) : (
                                <div class="w-full h-full bg-zinc-950 flex items-center justify-center relative">
                                    <div class="absolute inset-0 bg-cyber-grid opacity-20" />
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="56"
                                        height="56"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-cyber-pink/30 relative z-10"
                                    >
                                        <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" />
                                        <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18" />
                                        <path d="M4 22h16" />
                                        <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22" />
                                        <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22" />
                                        <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z" />
                                    </svg>
                                </div>
                            )}

                            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/20 to-transparent" />

                            {/* Category Tag */}
                            <div class="absolute bottom-6 right-8">
                                <span class="px-4 py-1.5 rounded-full bg-black/80 backdrop-blur-xl border border-white/10 text-[10px] font-mono text-zinc-300 uppercase tracking-widest group-hover:border-cyber-pink/50 group-hover:text-cyber-pink transition-all">
                                    {item.data.category || "EVENT"}
                                </span>
                            </div>
                        </div>

                        <div class="p-5 md:p-10 pt-4 space-y-6 flex-1 flex flex-col justify-between relative z-10">
                            <div class="space-y-4">
                                <h3 class="text-2xl font-black text-white group-hover:text-cyber-pink transition-colors leading-tight font-heading group-hover:translate-x-[-4px] duration-500">
                                    {item.data.title}
                                </h3>
                                <p class="text-sm text-zinc-500 line-clamp-2 leading-relaxed font-mono opacity-80 group-hover:opacity-100">
                                    {item.data.description}
                                </p>
                            </div>

                            <div class="pt-6 border-t border-white/5 flex items-center justify-between">
                                <div class="flex gap-2 flex-wrap">
                                    {item.data.tags
                                        .slice(0, 3)
                                        .map((tag: string) => (
                                            <span class="text-[9px] px-3 py-1 rounded-lg bg-zinc-950 text-zinc-500 border border-white/5 group-hover:border-cyber-pink/20 transition-colors">
                                                #{tag}
                                            </span>
                                        ))}
                                </div>
                                <div class="w-10 h-10 rounded-full flex items-center justify-center bg-zinc-950 border border-white/5 group-hover:bg-cyber-pink group-hover:text-zinc-950 transition-all duration-500">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="18"
                                        height="18"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="rotate-180"
                                    >
                                        <path d="M5 12h14" />
                                        <path d="m12 5 7 7-7 7" />
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</Layout>

<style is:global>
    @keyframes spin-slow {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }
    .animate-spin-slow {
        animation: spin-slow 12s linear infinite;
    }
</style>
