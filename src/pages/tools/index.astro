---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allTools = await getCollection("cybertools");

// Sort each category by subcategory alphabetically
const offensive = allTools
   .filter(
      (t) => t.data.category === "offensive" || t.data.category === "OFFENSIVE"
   )
   .sort((a, b) =>
      (a.data.subcategory ?? "").localeCompare(b.data.subcategory ?? "")
   );

const defensive = allTools
   .filter(
      (t) => t.data.category === "defensive" || t.data.category === "DEFENSIVE"
   )
   .sort((a, b) =>
      (a.data.subcategory ?? "").localeCompare(b.data.subcategory ?? "")
   );

// Pre-render all tool content for the modal
const offensiveRendered = await Promise.all(
   offensive.map(async (tool) => {
      const { Content } = await tool.render();
      return { tool, Content };
   })
);

const defensiveRendered = await Promise.all(
   defensive.map(async (tool) => {
      const { Content } = await tool.render();
      return { tool, Content };
   })
);
---

<Layout>
   <div class="space-y-12">
      <header class="space-y-4">
         <div class="flex items-center gap-3">
            <div class="h-[1px] w-12 bg-cyber-blue"></div>
            <span
               class="text-[10px] text-cyber-blue font-mono tracking-[0.3em] uppercase"
               >Arsenal_Manager</span
            >
         </div>
         <h1 class="text-4xl md:text-6xl font-black tracking-tighter">
            <span class="lang-ar">ترسانة الأدوات</span>
            <span class="lang-en text-2xl text-zinc-500 block"
               >CYBER_ARSENAL</span
            >
         </h1>
      </header>

      {/* Folder Selection View */}
      <div id="folder-selection" class="grid grid-cols-1 md:grid-cols-2 gap-8">
         {/* Offensive Folder Card */}
         <button
            onclick="showView('offensive-view')"
            class="group relative p-12 rounded-[3rem] bg-zinc-900/50 border border-white/5 backdrop-blur-xl hover:border-red-500/30 transition-all duration-500 text-right"
         >
            <div
               class="absolute -inset-1 bg-gradient-to-r from-red-500/10 to-transparent rounded-[3rem] blur opacity-0 group-hover:opacity-100 transition duration-500"
            >
            </div>
            <div class="relative space-y-8">
               <div
                  class="w-20 h-20 rounded-3xl bg-red-500/10 flex items-center justify-center text-red-500 shadow-[0_0_30px_rgba(239,68,68,0.1)] group-hover:scale-110 transition-transform"
               >
                  <svg
                     xmlns="http://www.w3.org/2000/svg"
                     width="40"
                     height="40"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="2"
                     stroke-linecap="round"
                     stroke-linejoin="round"
                     ><path
                        d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9l-1.2-2.2c-.4-.7-1.1-1.1-1.9-1.1H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"
                     ></path><circle cx="12" cy="13" r="2"></circle>
                  </svg>
               </div>
               <div class="space-y-2">
                  <h2
                     class="text-4xl font-black tracking-tighter text-white uppercase italic"
                  >
                     <span class="lang-ar">الأدوات الهجومية</span>
                     <span class="lang-en">OFFENSIVE</span>
                  </h2>
                  <p class="text-zinc-500 font-mono text-sm italic">
                     {offensive.length}
                     <span class="lang-ar"
                        >أداة مكتشفة (من أصل {allTools.length})</span
                     >
                  </p>
               </div>
               <div
                  class="flex items-center gap-2 text-red-500 font-mono text-xs uppercase tracking-widest opacity-50 group-hover:opacity-100 transition-opacity"
               >
                  <span>EXPLORE_DIRECTORY</span>
               </div>
            </div>
         </button>

         {/* Defensive Folder Card */}
         <button
            onclick="showView('defensive-view')"
            class="group relative p-12 rounded-[3rem] bg-zinc-900/50 border border-white/5 backdrop-blur-xl hover:border-cyber-blue/30 transition-all duration-500 text-right"
         >
            <div
               class="absolute -inset-1 bg-gradient-to-r from-cyber-blue/10 to-transparent rounded-[3rem] blur opacity-0 group-hover:opacity-100 transition duration-500"
            >
            </div>
            <div class="relative space-y-8">
               <div
                  class="w-20 h-20 rounded-3xl bg-cyber-blue/10 flex items-center justify-center text-cyber-blue shadow-[0_0_30px_rgba(56,189,248,0.1)] group-hover:scale-110 transition-transform"
               >
                  <svg
                     xmlns="http://www.w3.org/2000/svg"
                     width="40"
                     height="40"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="2"
                     stroke-linecap="round"
                     stroke-linejoin="round"
                     ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"
                     ></path><path d="M12 8v4"></path><path d="M12 16h.01"
                     ></path>
                  </svg>
               </div>
               <div class="space-y-2">
                  <h2
                     class="text-4xl font-black tracking-tighter text-white uppercase italic"
                  >
                     <span class="lang-ar">الأدوات الدفاعية</span>
                     <span class="lang-en">DEFENSIVE</span>
                  </h2>
                  <p class="text-zinc-500 font-mono text-sm italic">
                     {defensive.length}
                     <span class="lang-ar">أداة مكتشفة</span>
                  </p>
               </div>
               <div
                  class="flex items-center gap-2 text-cyber-blue font-mono text-xs uppercase tracking-widest opacity-50 group-hover:opacity-100 transition-opacity"
               >
                  <span>EXPLORE_DIRECTORY</span>
               </div>
            </div>
         </button>
      </div>

      {/* Offensive Detail View */}
      <div id="offensive-view" class="hidden space-y-8">
         <button
            onclick="showView('folder-selection')"
            class="flex items-center gap-2 text-xs text-zinc-500 hover:text-red-500 transition-colors uppercase font-mono tracking-widest mb-8"
         >
            <svg
               xmlns="http://www.w3.org/2000/svg"
               width="14"
               height="14"
               viewBox="0 0 24 24"
               fill="none"
               stroke="currentColor"
               stroke-width="2"
               stroke-linecap="round"
               stroke-linejoin="round"
               ><path d="m15 18-6-6 6-6"></path>
            </svg>
            <span class="lang-ar">العودة للملفات</span>
            <span class="lang-en">BACK_TO_ROOT</span>
         </button>

         <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
               offensiveRendered.map(({ tool }) => (
                  <button
                     onclick={`openModal('modal-${tool.slug}')`}
                     class="group p-6 rounded-3xl bg-white/[0.02] border border-white/5 hover:border-red-500/30 transition-all duration-500 relative overflow-hidden text-right w-full"
                  >
                     <div class="space-y-4 relative z-10">
                        <span class="text-[8px] font-mono px-2 py-1 rounded-md bg-red-500/10 text-red-400 border border-red-500/20 uppercase">
                           {tool.data.subcategory}
                        </span>
                        <h3 class="text-xl font-bold group-hover:text-red-400 transition-colors uppercase font-mono tracking-tighter">
                           {tool.data.title}
                        </h3>
                        <p class="text-xs text-zinc-500 font-mono leading-relaxed">
                           {tool.data.description}
                        </p>
                     </div>
                  </button>
               ))
            }
         </div>
      </div>

      {/* Defensive Detail View */}
      <div id="defensive-view" class="hidden space-y-8">
         <button
            onclick="showView('folder-selection')"
            class="flex items-center gap-2 text-xs text-zinc-500 hover:text-cyber-blue transition-colors uppercase font-mono tracking-widest mb-8"
         >
            <svg
               xmlns="http://www.w3.org/2000/svg"
               width="14"
               height="14"
               viewBox="0 0 24 24"
               fill="none"
               stroke="currentColor"
               stroke-width="2"
               stroke-linecap="round"
               stroke-linejoin="round"
               ><path d="m15 18-6-6 6-6"></path>
            </svg>
            <span class="lang-ar">العودة للملفات</span>
            <span class="lang-en">BACK_TO_ROOT</span>
         </button>

         <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
               defensiveRendered.map(({ tool }) => (
                  <button
                     onclick={`openModal('modal-${tool.slug}')`}
                     class="group p-6 rounded-3xl bg-white/[0.02] border border-white/5 hover:border-cyber-blue/30 transition-all duration-500 relative overflow-hidden text-right w-full"
                  >
                     <div class="space-y-4 relative z-10">
                        <span class="text-[8px] font-mono px-2 py-1 rounded-md bg-cyber-blue/10 text-cyber-blue border border-cyber-blue/20 uppercase">
                           {tool.data.subcategory}
                        </span>
                        <h3 class="text-xl font-bold group-hover:text-cyber-blue transition-colors uppercase font-mono tracking-tighter">
                           {tool.data.title}
                        </h3>
                        <p class="text-xs text-zinc-500 font-mono leading-relaxed">
                           {tool.data.description}
                        </p>
                     </div>
                  </button>
               ))
            }
         </div>
      </div>
   </div>

   {/* ===== MODALS ===== */}

   {/* Offensive Modals */}
   {
      offensiveRendered.map(({ tool, Content }) => (
         <div
            id={`modal-${tool.slug}`}
            class="fixed inset-0 z-50 hidden items-center justify-center p-4 md:p-8"
            onclick="closeModalOnBackdrop(event, this)"
         >
            {/* Backdrop */}
            <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" />
            {/* Content */}
            <div class="relative w-full max-w-3xl max-h-[85vh] overflow-y-auto rounded-3xl bg-zinc-950 border border-red-500/20 shadow-2xl shadow-red-500/5">
               {/* Header */}
               <div class="sticky top-0 z-10 flex items-start justify-between gap-4 p-6 bg-zinc-950/95 backdrop-blur-sm border-b border-white/5">
                  <div class="space-y-1 text-right">
                     <span class="text-[9px] font-mono px-2 py-1 rounded-md bg-red-500/10 text-red-400 border border-red-500/20 uppercase">
                        {tool.data.category} / {tool.data.subcategory}
                     </span>
                     <h2 class="text-2xl font-black uppercase font-mono tracking-tighter text-white mt-2">
                        {tool.data.title}
                     </h2>
                     <p class="text-sm text-zinc-400 font-mono">
                        {tool.data.description}
                     </p>
                  </div>
                  <button
                     onclick={`closeModal('modal-${tool.slug}')`}
                     class="mt-1 flex-shrink-0 w-8 h-8 rounded-full bg-white/5 hover:bg-red-500/20 flex items-center justify-center text-zinc-400 hover:text-red-400 transition-colors"
                  >
                     <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                     >
                        <path d="M18 6 6 18" />
                        <path d="m6 6 12 12" />
                     </svg>
                  </button>
               </div>
               {/* Body */}
               <div
                  class="p-6 prose prose-invert prose-cyber max-w-none
          prose-headings:font-black prose-headings:tracking-tighter prose-headings:text-right
          prose-h1:text-2xl prose-h2:text-xl prose-h2:border-b prose-h2:border-white/5 prose-h2:pb-2 prose-h2:mt-6
          prose-h3:text-base prose-h3:text-red-400/80 prose-h3:font-mono prose-h3:uppercase prose-h3:tracking-widest
          prose-p:text-zinc-400 prose-p:leading-relaxed prose-p:text-right
          prose-code:text-red-400 prose-code:bg-red-500/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:before:content-none prose-code:after:content-none prose-code:text-sm
          prose-pre:bg-zinc-900/80 prose-pre:border prose-pre:border-red-500/10 prose-pre:rounded-2xl prose-pre:p-4 prose-pre:shadow-inner
          prose-strong:text-white
          prose-a:text-red-400 prose-a:no-underline hover:prose-a:underline
          prose-ul:text-right prose-li:text-zinc-400 prose-li:my-1
          prose-table:w-full prose-table:border-collapse
          prose-th:text-right prose-th:text-zinc-300 prose-th:font-mono prose-th:text-xs prose-th:uppercase prose-th:tracking-wider prose-th:pb-2 prose-th:border-b prose-th:border-white/10
          prose-td:text-zinc-400 prose-td:py-2 prose-td:border-b prose-td:border-white/5 prose-td:text-right prose-td:text-sm
          prose-blockquote:border-l-red-500/50 prose-blockquote:bg-red-500/5 prose-blockquote:rounded-r-xl prose-blockquote:px-4 prose-blockquote:py-2 prose-blockquote:my-4 prose-blockquote:not-italic
          prose-blockquote:text-zinc-300 prose-blockquote:border-l-2"
               >
                  <Content />
               </div>
               {/* Tags */}
               {tool.data.tags && tool.data.tags.length > 0 && (
                  <div class="px-6 pb-6 flex flex-wrap gap-2 justify-end">
                     {tool.data.tags.map((tag: string) => (
                        <span class="text-[9px] font-mono px-2 py-1 rounded-full bg-white/5 text-zinc-500 border border-white/5">
                           #{tag}
                        </span>
                     ))}
                  </div>
               )}
            </div>
         </div>
      ))
   }

   {/* Defensive Modals */}
   {
      defensiveRendered.map(({ tool, Content }) => (
         <div
            id={`modal-${tool.slug}`}
            class="fixed inset-0 z-50 hidden items-center justify-center p-4 md:p-8"
            onclick="closeModalOnBackdrop(event, this)"
         >
            {/* Backdrop */}
            <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" />
            {/* Content */}
            <div class="relative w-full max-w-3xl max-h-[85vh] overflow-y-auto rounded-3xl bg-zinc-950 border border-cyber-blue/20 shadow-2xl shadow-cyber-blue/5">
               {/* Header */}
               <div class="sticky top-0 z-10 flex items-start justify-between gap-4 p-6 bg-zinc-950/95 backdrop-blur-sm border-b border-white/5">
                  <div class="space-y-1 text-right">
                     <span class="text-[9px] font-mono px-2 py-1 rounded-md bg-cyber-blue/10 text-cyber-blue border border-cyber-blue/20 uppercase">
                        {tool.data.category} / {tool.data.subcategory}
                     </span>
                     <h2 class="text-2xl font-black uppercase font-mono tracking-tighter text-white mt-2">
                        {tool.data.title}
                     </h2>
                     <p class="text-sm text-zinc-400 font-mono">
                        {tool.data.description}
                     </p>
                  </div>
                  <button
                     onclick={`closeModal('modal-${tool.slug}')`}
                     class="mt-1 flex-shrink-0 w-8 h-8 rounded-full bg-white/5 hover:bg-cyber-blue/20 flex items-center justify-center text-zinc-400 hover:text-cyber-blue transition-colors"
                  >
                     <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                     >
                        <path d="M18 6 6 18" />
                        <path d="m6 6 12 12" />
                     </svg>
                  </button>
               </div>
               {/* Body */}
               <div
                  class="p-6 prose prose-invert prose-cyber max-w-none
          prose-headings:font-black prose-headings:tracking-tighter prose-headings:text-right
          prose-h1:text-2xl prose-h2:text-xl prose-h2:border-b prose-h2:border-white/5 prose-h2:pb-2 prose-h2:mt-6
          prose-h3:text-base prose-h3:text-cyber-blue/80 prose-h3:font-mono prose-h3:uppercase prose-h3:tracking-widest
          prose-p:text-zinc-400 prose-p:leading-relaxed prose-p:text-right
          prose-code:text-cyber-blue prose-code:bg-cyber-blue/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:before:content-none prose-code:after:content-none prose-code:text-sm
          prose-pre:bg-zinc-900/80 prose-pre:border prose-pre:border-cyber-blue/10 prose-pre:rounded-2xl prose-pre:p-4 prose-pre:shadow-inner
          prose-strong:text-white
          prose-a:text-cyber-blue prose-a:no-underline hover:prose-a:underline
          prose-ul:text-right prose-li:text-zinc-400 prose-li:my-1
          prose-table:w-full prose-table:border-collapse
          prose-th:text-right prose-th:text-zinc-300 prose-th:font-mono prose-th:text-xs prose-th:uppercase prose-th:tracking-wider prose-th:pb-2 prose-th:border-b prose-th:border-white/10
          prose-td:text-zinc-400 prose-td:py-2 prose-td:border-b prose-td:border-white/5 prose-td:text-right prose-td:text-sm
          prose-blockquote:border-l-cyber-blue/50 prose-blockquote:bg-cyber-blue/5 prose-blockquote:rounded-r-xl prose-blockquote:px-4 prose-blockquote:py-2 prose-blockquote:my-4 prose-blockquote:not-italic
          prose-blockquote:text-zinc-300 prose-blockquote:border-l-2"
               >
                  <Content />
               </div>
               {/* Tags */}
               {tool.data.tags && tool.data.tags.length > 0 && (
                  <div class="px-6 pb-6 flex flex-wrap gap-2 justify-end">
                     {tool.data.tags.map((tag: string) => (
                        <span class="text-[9px] font-mono px-2 py-1 rounded-full bg-white/5 text-zinc-500 border border-white/5">
                           #{tag}
                        </span>
                     ))}
                  </div>
               )}
            </div>
         </div>
      ))
   }
</Layout>

<script>
   function showView(id: string) {
      const views = ["folder-selection", "offensive-view", "defensive-view"];
      views.forEach((v) => {
         const el = document.getElementById(v);
         if (el) {
            if (v === id) {
               el.classList.remove("hidden");
            } else {
               el.classList.add("hidden");
            }
         }
      });
      window.scrollTo({ top: 0, behavior: "smooth" });
   }

   function openModal(id: string) {
      const modal = document.getElementById(id);
      if (modal) {
         modal.classList.remove("hidden");
         modal.classList.add("flex");
         document.body.style.overflow = "hidden";
      }
   }

   function closeModal(id: string) {
      const modal = document.getElementById(id);
      if (modal) {
         modal.classList.add("hidden");
         modal.classList.remove("flex");
         document.body.style.overflow = "";
      }
   }

   function closeModalOnBackdrop(event: MouseEvent, modal: HTMLElement) {
      // Close only if clicking the backdrop itself (not the content inside)
      if (
         event.target === modal ||
         (event.target as HTMLElement).closest(".absolute.inset-0")
      ) {
         modal.classList.add("hidden");
         modal.classList.remove("flex");
         document.body.style.overflow = "";
      }
   }

   // Close on Escape key
   document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
         document.querySelectorAll('[id^="modal-"]').forEach((modal) => {
            if (!modal.classList.contains("hidden")) {
               (modal as HTMLElement).classList.add("hidden");
               (modal as HTMLElement).classList.remove("flex");
               document.body.style.overflow = "";
            }
         });
      }
   });

   // Expose functions globally
   (window as any).showView = showView;
   (window as any).openModal = openModal;
   (window as any).closeModal = closeModal;
   (window as any).closeModalOnBackdrop = closeModalOnBackdrop;
</script>
