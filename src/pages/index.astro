---
import Layout from "../layouts/Layout.astro";
import Card from "../components/BentoGrid/Card.astro";
import TerminalWidget from "../components/TerminalWidget.astro";
import SecurityBadge from "../components/SecurityBadge.astro";
import { initialNodes } from "../data/portfolioData";
import { ThreatMap } from "../components/ThreatMap";

// Filter data for easy rendering
const skills = initialNodes.find((n) => n.id === "skills")?.data.details || [];
const projects = initialNodes.filter(
  (n) => n.data.category === "projects" && !n.id.includes("-root")
);
const contactInfo =
  initialNodes.find((n) => n.id === "contact")?.data.details || [];
const university = initialNodes.find((n) => n.id === "university")?.data || {};

const saeed = initialNodes.find((n) => n.id === "saeed")?.data || {
  label: "سعيد",
  description: "طالب أمن سيبراني",
};

const seoTitle = "Saeed Barran";
const seoDescription =
  "موقع سعيد بران لعرض مشاريع الأمن السيبراني، الأدوات، الشروحات، والإنجازات التقنية باللغة العربية والإنجليزية.";
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Saeed Barran",
  jobTitle: "Cybersecurity Student",
  description:
    "BSc cybersecurity student (expected 2027), focused on social engineering, network assessment, and web penetration testing.",
  email: "mailto:sb3ly@proton.me",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Al-Mukalla",
    addressCountry: "YE",
  },
  sameAs: ["https://github.com/sb3lr", "https://youtube.com/@0xsb3lr"],
};
---

<Layout
  title={seoTitle}
  description={seoDescription}
  ogImage="/profile.jpg"
  keywords={["أمن سيبراني", "اختبار اختراق", "Cybersecurity Portfolio", "OSINT"]}
  schema={personSchema}
>
  <div class="space-y-20 md:space-y-32">
    {/* Aesthetic Background Blobs */}
    <div
      class="absolute top-20 left-10 w-64 h-64 bg-cyber-purple/20 blur-[120px] rounded-full animate-pulse pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-1/2 right-10 w-96 h-96 bg-cyber-blue/10 blur-[150px] rounded-full animate-pulse pointer-events-none"
      style="animation-delay: 1s"
    >
    </div>

    {/* Hero Section */}
    <section
      id="home"
      class="relative min-h-[80vh] md:min-h-[90vh] flex items-center pt-6 md:pt-24 overflow-hidden"
    >
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12 w-full items-center">
        {/* Left Side: Identity Dashboard */}
        <div class="lg:col-span-7 space-y-8 relative z-20">
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div
                class="px-4 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center gap-2"
              >
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"
                ></span>
                <span
                  class="font-mono text-[10px] tracking-[0.2em] text-emerald-500 uppercase"
                  >System_Active</span
                >
              </div>
              <div
                class="px-4 py-1.5 rounded-full bg-cyber-purple/10 border border-cyber-purple/20"
              >
                <span
                  class="font-mono text-[10px] tracking-[0.2em] text-cyber-purple uppercase"
                  >v.2026.OS</span
                >
              </div>
            </div>

            <div class="space-y-4">
              <div class="space-y-1">
                <span
                  class="text-[9px] text-zinc-500 font-mono tracking-[0.25em] md:tracking-[0.4em] uppercase block opacity-50"
                  >Resident_Cyber_specialist</span
                >
                <h1
                  class="text-3xl sm:text-4xl md:text-5xl font-bold font-heading tracking-tight leading-tight group"
                >
                  <span
                    class="lang-ar text-gradient bg-gradient-to-r from-white via-white to-cyber-purple block drop-shadow-[0_0_15px_rgba(168,85,247,0.2)] pb-2"
                  >
                    سعيد بران
                  </span>
                  <span
                    class="lang-en text-gradient bg-gradient-to-r from-cyber-purple/80 to-cyber-blue/80 block text-2xl md:text-3xl mt-1"
                  >
                    Saeed Barran
                  </span>
                </h1>
              </div>

              <div class="relative max-w-xl">
                <div
                  class="absolute -left-3 top-1 bottom-1 w-[1px] bg-cyber-purple/30"
                >
                </div>
                <p
                  class="text-sm md:text-base text-zinc-500 font-mono leading-relaxed pl-4 break-words"
                >
                  <span class="lang-ar block">
                    <span class="text-cyber-purple/60 font-bold">#</span> طالب أمن
                    سيبراني بكالوريوس (تخرج 2027) ملم بالهندسة الاجتماعية، فحص
                    الشبكات، واختبار اختراق المواقع، وباحث في المجال لأكثر من 5 سنوات.
                  </span>
                  <span class="lang-en block">
                    <span class="text-cyber-blue/60 font-bold">#</span> BSc
                    cybersecurity student (2027) focused on social engineering,
                    network assessment, and web pentesting with 5+ years of
                    independent research.
                  </span>
                </p>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
            <div
              class="p-4 md:p-6 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-md"
            >
              <span
                class="text-[9px] text-zinc-600 font-mono uppercase tracking-widest block mb-2"
                >Research_Years</span
              >
              <span class="text-cyber-blue font-bold text-xl font-mono">5+ YEARS</span
              >
            </div>
            <div
              class="p-4 md:p-6 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-md"
            >
              <span
                class="text-[9px] text-zinc-600 font-mono uppercase tracking-widest block mb-2"
                >Degree_Status</span
              >
              <span class="text-cyber-purple font-bold text-xl font-mono">BSc_2027</span
              >
            </div>
            <div
              class="p-4 md:p-6 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-md sm:col-span-2 md:col-span-1"
            >
              <span
                class="text-[9px] text-zinc-600 font-mono uppercase tracking-widest block mb-2"
                >Current_Goal</span
              >
              <span class="text-emerald-500 font-bold text-[13px] md:text-lg font-mono whitespace-nowrap">eJPT_IN_PROGRESS</span
              >
            </div>
          </div>

          <div class="flex flex-wrap gap-3 mt-4 md:mt-8">
            <a
              href="#contact"
              class="flex-1 md:flex-none px-6 md:px-8 py-3 md:py-4 rounded-xl md:rounded-2xl bg-white text-black font-bold hover:bg-zinc-200 transition-all text-center text-sm md:text-base"
            >
              <span class="lang-ar">تواصل معي</span>
              <span class="lang-en">Get in Touch</span>
            </a>
            <a
              href="#projects"
              class="flex-1 md:flex-none px-6 md:px-8 py-3 md:py-4 rounded-xl md:rounded-2xl bg-white/5 border border-white/10 text-white font-bold hover:bg-white/10 transition-all font-mono text-center text-sm md:text-base"
            >
              <span class="lang-ar">عرض المشاريع_</span>
              <span class="lang-en">View_Projects_</span>
            </a>
            <a
              href="/cv/Saeed_Barran_CV.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full sm:w-auto px-6 md:px-8 py-3 md:py-4 rounded-xl md:rounded-2xl bg-cyber-purple/15 border border-cyber-purple/30 text-cyber-purple font-bold hover:bg-cyber-purple/25 transition-all text-center text-sm md:text-base"
            >
              <span class="lang-ar">تحميل السيرة الذاتية (PDF)</span>
              <span class="lang-en">Download CV (PDF)</span>
            </a>
          </div>
        </div>

        {/* Right Side: Visual Identity */}
        <div class="lg:col-span-5 relative group order-first lg:order-last">
          <div
            class="absolute -inset-4 bg-gradient-to-tr from-cyber-purple/30 to-cyber-blue/30 blur-3xl opacity-50 animate-pulse"
          >
          </div>
          <div
              class="relative aspect-square md:aspect-[4/5] rounded-3xl md:rounded-[3rem] overflow-hidden border border-white/10 bg-zinc-900 shadow-2xl overflow-hidden group"
          >
            <div
              class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent z-10 opacity-60"
            >
            </div>
            <img
              src="/profile.jpg"
              alt="سعيد بران"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="w-full h-full object-cover grayscale-[0.2] transition-transform duration-700 group-hover:scale-110"
            />

            {/* HUD Overlay Elements */}
            <div class="absolute top-6 right-6 z-20">
              <div
                class="bg-black/40 backdrop-blur-md border border-white/10 px-4 py-2 rounded-xl"
              >
                <div class="flex items-center gap-3">
                  <div
                    class="w-2 h-2 rounded-full bg-cyber-purple animate-ping"
                  >
                  </div>
                  <span
                    class="text-[10px] font-mono text-zinc-300 uppercase tracking-widest"
                    >Scanning_Bio...</span
                  >
                </div>
              </div>
            </div>

            <div class="absolute bottom-8 left-8 right-8 z-20">
              <div
                class="bg-black/40 backdrop-blur-md border border-white/10 p-4 md:p-6 rounded-2xl"
              >
                <div class="flex justify-between items-end">
                  <div class="space-y-1">
                    <span
                      class="text-[10px] font-mono text-zinc-500 uppercase tracking-tighter"
                      >Identity_Scan</span
                    >
                    <h3 class="text-white font-bold text-base md:text-lg tracking-tight">
                      Saeed_Bran.data
                    </h3>
                  </div>
                  <div class="text-right">
                    <div class="text-cyber-blue font-mono text-xs">
                      89% Match
                    </div>
                  </div>
                </div>
                <div
                  class="mt-4 w-full h-1 bg-white/5 rounded-full overflow-hidden"
                >
                  <div
                    class="h-full bg-gradient-to-r from-cyber-purple to-cyber-blue animate-progress"
                    style="width: 89%; animation-duration: 3s"
                  >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Main Content Grid */}
    <div class="grid grid-cols-1 md:grid-cols-6 gap-4 md:gap-6">
      {/* About Section */}
      <Card id="about" glowColor="purple" className="md:col-span-4">
        <div slot="title">
          <span class="lang-ar">عنّي / WHO_AM_I</span>
          <span class="lang-en">ABOUT / WHO_AM_I</span>
        </div>
        <div class="flex flex-col md:flex-row gap-8 items-center">
          <div class="relative group">
            <div
              class="absolute -inset-1 bg-gradient-to-r from-cyber-purple to-cyber-blue rounded-full blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"
            >
            </div>
            <div
              class="relative w-32 h-32 rounded-3xl overflow-hidden border-2 border-white/10 bg-zinc-900 flex items-center justify-center shadow-2xl group-hover:scale-105 transition-transform duration-500"
            >
              <img
                src="/profile.jpg"
                alt="سعيد بران"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
              />
              <div
                class="hidden w-full h-full items-center justify-center text-5xl bg-gradient-to-br from-cyber-purple/20 to-cyber-blue/20"
              >
                👤
              </div>
            </div>
          </div>
          <div class="flex-1 space-y-4 text-right">
            <p class="text-zinc-400 text-base md:text-lg leading-relaxed">
              <span class="lang-ar"
                >{saeed.description} لم أعمل بوظيفة رسمية بعد، لكنني نفذت مشاريع
                تقنية كبيرة بشكل فردي وأركز على التطبيق العملي الحقيقي.</span
              >
              <span class="lang-en"
                >{saeed.descriptionEn} I have not held a formal job role yet,
                but I have built major solo projects and focus on real hands-on
                execution.</span
              >
            </p>
            <div class="flex flex-wrap gap-3 justify-end uppercase">
              <span
                class="px-3 py-1 rounded-full bg-zinc-900 border border-white/5 text-zinc-500 text-xs font-mono"
                >#CYBER_LABS</span
              >
              <span
                class="px-3 py-1 rounded-full bg-zinc-900 border border-white/5 text-zinc-500 text-xs font-mono"
                >#RED_TEAMING</span
              >
              <span
                class="px-3 py-1 rounded-full bg-zinc-900 border border-white/5 text-zinc-500 text-xs font-mono"
                >#OSINT</span
              >
            </div>
          </div>
        </div>
      </Card>

      {/* Terminal Widget Section */}
      <Card
        glowColor="blue"
        className="md:col-span-2 overflow-hidden"
      >
        <div slot="title">
          <span class="lang-ar">سجل النظام / SYSTEM_LOGS</span>
          <span class="lang-en">SYSTEM_LOGS / CLI</span>
        </div>
        <div class="h-64 md:h-72 overflow-hidden">
          <TerminalWidget />
        </div>
      </Card>

      {/* Education & Status Row */}
      <Card glowColor="indigo" className="md:col-span-3">
        <div slot="title">
          <span class="lang-ar">التعليم / EDUCATION</span>
          <span class="lang-en">EDUCATION / LEARNING</span>
        </div>
        <div class="flex items-start gap-4 text-right justify-end">
          <div>
            <h4 class="text-white font-bold text-lg">
              <span class="lang-ar">{university.label}</span>
              <span class="lang-en">{university.labelEn}</span>
            </h4>
            <p class="text-zinc-500 mt-1">
              <span class="lang-ar">{university.description}</span>
              <span class="lang-en">{university.descriptionEn}</span>
            </p>
          </div>
          <div
            class="p-3 rounded-xl bg-indigo-500/10 border border-indigo-500/20 text-indigo-50"
          >
            🎓
          </div>
        </div>
      </Card>

      <Card glowColor="purple" className="md:col-span-3">
        <div slot="title">
          <span class="lang-ar">أهم الإنجازات / HIGHLIGHTS</span>
          <span class="lang-en">TOP / HIGHLIGHTS</span>
        </div>
        <div class="space-y-3 text-right">
          <div class="rounded-xl border border-white/5 bg-white/[0.02] p-3">
            <p class="text-zinc-300 text-sm">
              <span class="lang-ar">الإشراف على فعالية سلامة توعوية في جامعة العلوم والتكنولوجيا.</span>
              <span class="lang-en">Supervised a SAFETY awareness event at the University of Science and Technology.</span>
            </p>
          </div>
          <div class="rounded-xl border border-white/5 bg-white/[0.02] p-3">
            <p class="text-zinc-300 text-sm">
              <span class="lang-ar">اكتشاف والإبلاغ عن عدة ثغرات في موقع الجامعة بشكل مسؤول.</span>
              <span class="lang-en">Discovered and responsibly reported multiple vulnerabilities in the university website.</span>
            </p>
          </div>
          <div class="rounded-xl border border-white/5 bg-white/[0.02] p-3">
            <p class="text-zinc-300 text-sm">
              <span class="lang-ar">تنفيذ 3 مشاريع أمنية كبيرة بشكل فردي كامل.</span>
              <span class="lang-en">Built 3 major cybersecurity projects fully solo.</span>
            </p>
          </div>
        </div>
      </Card>

      {/* Skills Section */}
      <Card id="skills" glowColor="orange" className="md:col-span-6">
        <div slot="title">
          <span class="lang-ar">المهارات التقنية / SKILLS</span>
          <span class="lang-en">TECHNICAL_SKILLS / TOOLS</span>
        </div>
        <div class="flex flex-wrap gap-3 justify-center">
          {
            skills.map((skill: string) => (
              <span class="px-4 py-2 rounded-xl bg-orange-500/5 border border-white/5 text-orange-200/80 text-sm font-mono hover:bg-orange-500/10 transition-all hover:border-orange-500/30 cursor-default">
                {skill}
              </span>
            ))
          }
        </div>
      </Card>

      {/* Certifications Section */}
      <Card id="certificates" glowColor="green" className="md:col-span-6">
        <div slot="title">
          <span class="lang-ar">الشهادات والاعتمادات / ACCREDITATIONS</span>
          <span class="lang-en">CERTIFICATIONS / BADGES</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <SecurityBadge
            icon="🛡️"
            label="Google Cyber"
            issuer="COURSERA"
            color="blue"
            link="https://www.coursera.org/account/accomplishments/professional-cert/SSTHEZHGVY6S"
          />
          <SecurityBadge
            icon="💻"
            label="Web Developer"
            issuer="PROFESSIONAL"
            color="purple"
            link="#"
          />
          <SecurityBadge
            icon="📊"
            label="ICDL"
            issuer="INTERNATIONAL"
            color="green"
            link="#"
          />
          <SecurityBadge
            icon="📚"
            label="English Files"
            issuer="STARTER"
            color="orange"
            link="#"
          />
        </div>
      </Card>

      {/* Experience / Projects Detailed Section */}
      <Card id="projects" glowColor="pink" className="md:col-span-6">
        <div slot="title">
          <span class="lang-ar">المشاريع والخبرات / PROJECTS_&_EXP</span>
          <span class="lang-en">EXPERIENCE / DEVELOPMENTS</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            projects.map((project) => (
              <div class="group/proj p-6 rounded-2xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.05] transition-all hover:-translate-y-1">
                <div class="flex items-center gap-4 mb-4">
                  <div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center text-2xl">
                    {project.id === "exp-arp"
                      ? "🕸️"
                      : project.id === "exp-monitor"
                      ? "📡"
                      : "🧩"}
                  </div>
                  <h4 class="text-white font-bold text-lg">
                    <span class="lang-ar">{project.data.label}</span>
                    <span class="lang-en">{project.data.labelEn}</span>
                  </h4>
                </div>
                <p class="text-zinc-500 text-sm leading-relaxed mb-4">
                  <span class="lang-ar">{project.data.description}</span>
                  <span class="lang-en">{project.data.descriptionEn}</span>
                </p>
                {project.data.link && (
                  <a
                    href={project.data.link}
                    target="_blank"
                    class="inline-flex items-center gap-2 text-pink-400 text-sm hover:underline font-mono uppercase tracking-widest"
                  >
                    <span class="lang-ar">الدخول للرابط --&gt;</span>
                    <span class="lang-en">Access_Link --&gt;</span>
                  </a>
                )}
              </div>
            ))
          }
        </div>
      </Card>

      {/* Contact Section */}
      <Card id="contact" glowColor="indigo" className="md:col-span-6">
        <div slot="title">
          <span class="lang-ar">قنوات التواصل / CONNECT</span>
          <span class="lang-en">CONTACT / CHANNELS</span>
        </div>
        <div class="py-10 px-4 space-y-10">
          <div class="text-center space-y-3">
            <h2
              class="text-2xl md:text-4xl font-black tracking-tighter text-white"
            >
              <span class="lang-ar">لنعمل معاً على تأمين المستقبل الرقمي</span>
              <span class="lang-en">Let's Secure the Future Together</span>
            </h2>
            <p class="text-zinc-500 font-mono text-xs max-w-xl mx-auto">
              <span class="lang-ar"
                >متاح دائماً للمناقشات التقنية والمشاريع الجديدة.</span
              >
              <span class="lang-en"
                >Always available for technical discussions and new projects.</span
              >
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {
              contactInfo.map((info: string, i: number) => (
                <div class="flex flex-col items-center gap-4 p-8 rounded-3xl bg-indigo-500/[0.02] border border-indigo-500/10 group transition-all duration-500 hover:bg-indigo-500/10 hover:border-indigo-500/30 text-center">
                  <div class="w-16 h-16 rounded-2xl bg-indigo-500/10 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-500 shadow-[0_0_20px_rgba(99,102,241,0.1)]">
                    {i === 0 ? "📧" : i === 1 ? "📞" : "📍"}
                  </div>
                  <div class="space-y-1">
                    <span class="text-[9px] text-zinc-600 font-mono uppercase tracking-[0.2em]">
                      <span class="lang-ar">
                        {i === 0
                          ? "البريد الإلكتروني"
                          : i === 1
                          ? "رقم الهاتف"
                          : "الموقع"}
                      </span>
                      <span class="lang-en">
                        {i === 0 ? "EMAIL" : i === 1 ? "PHONE" : "LOCATION"}
                      </span>
                    </span>
                    <h4
                      class={`text-zinc-300 text-lg font-bold font-mono tracking-tight ${
                        i === 0 ? "break-all" : "break-words"
                      }`}
                    >
                      <span
                        dir={i === 0 || i === 1 ? "ltr" : "auto"}
                        class={i === 0 || i === 1
                          ? "inline-block text-left [unicode-bidi:isolate]"
                          : "inline-block"}
                      >
                        {info}
                      </span>
                    </h4>
                  </div>
                </div>
              ))
            }
          </div>

          <div class="flex flex-wrap justify-center gap-4 pt-4">
            <a
              href="https://github.com/sb3lr"
              target="_blank"
              class="group relative px-8 py-4 rounded-xl border border-white/5 bg-zinc-950 flex items-center gap-3 text-zinc-400 hover:text-white hover:border-white transition-all duration-500 overflow-hidden"
            >
              <div
                class="absolute inset-0 bg-white/5 translate-y-full group-hover:translate-y-0 transition-transform duration-500"
              >
              </div>
              <span class="relative z-10 text-xl font-bold">GitHub</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="relative z-10 lucide lucide-github opacity-50 group-hover:opacity-100 transition-opacity"
                ><path
