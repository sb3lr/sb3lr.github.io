---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const reports = await getCollection("reports");
  return reports.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const seoTitle = `${entry.data.title} | تقرير اختبار اختراق | سعيد بران`;
---

<Layout
  title={seoTitle}
  description={entry.data.description}
  type="article"
  publishedTime={entry.data.publishDate}
  keywords={["report", "security", "penetration testing", ...entry.data.tags]}
>
  <section class="py-12 md:py-20">
    <article class="w-full max-w-4xl mx-auto space-y-12">
      <header class="text-center space-y-8 pb-12 border-b border-white/5">
        <div class="flex justify-center">
          <a href="/reports" class="inline-flex items-center gap-3 px-6 py-2.5 rounded-full bg-white/5 border border-white/10 text-xs text-zinc-400 hover:text-white hover:bg-cyber-purple/20 hover:border-cyber-purple/50 transition-all duration-500 font-mono uppercase tracking-[0.2em] group backdrop-blur-md shadow-xl">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform rotate-180"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            <span class="lang-ar">العودة للتقارير</span>
            <span class="lang-en">Back to Reports</span>
          </a>
        </div>

        <div class="flex items-center gap-2 justify-center flex-wrap">
          {entry.data.publishDate && (
            <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-widest">
              {new Date(entry.data.publishDate).toLocaleDateString("ar-SA", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </span>
          )}
          <span class="text-[10px] font-mono px-2.5 py-1 rounded-md bg-cyber-purple/10 text-cyber-purple border border-cyber-purple/20 uppercase">Report</span>
        </div>

        <h1 class="text-xl md:text-3xl font-black tracking-tight text-white leading-tight">{entry.data.title}</h1>
        <p class="text-zinc-400 text-sm md:text-base leading-relaxed">{entry.data.description}</p>
      </header>

      <div class="article-prose article-prose--report prose prose-invert max-w-none">
        <Content />
      </div>

      {entry.data.tags && entry.data.tags.length > 0 && (
        <footer class="pt-12 border-t border-white/5 flex flex-wrap gap-3 justify-center">
          {entry.data.tags.map((tag: string) => (
            <span class="text-[10px] font-mono px-4 py-1.5 rounded-full bg-cyber-purple/5 text-cyber-purple/80 border border-cyber-purple/20 hover:bg-cyber-purple/10 transition-colors">
              #{tag}
            </span>
          ))}
        </footer>
      )}
    </article>
  </section>
</Layout>

<style is:global>
  .article-prose--report h1 {
    text-align: right;
    background: linear-gradient(to bottom right, #fff, #c084fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 2rem !important;
    font-size: 2.25rem !important;
    font-weight: 900 !important;
  }

  .article-prose--report h2 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #f3e8ff !important;
    font-size: 1.5rem !important;
    font-weight: 800 !important;
    margin: 3.5rem 0 1.5rem 0 !important;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(168, 85, 247, 0.15);
  }

  .article-prose--report h2::before {
    content: "";
    width: 4px;
    height: 1.5rem;
    background: #a855f7;
    border-radius: 99px;
  }

  .article-prose--report h3 {
    color: #d8b4fe !important;
    font-size: 1.2rem !important;
    font-weight: 700 !important;
    margin-top: 2rem !important;
  }

  .article-prose--report p {
    line-height: 1.85;
    color: #a1a1aa !important;
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }

  .article-prose--report strong {
    color: #e9d5ff !important;
    font-weight: 600;
  }

  .article-prose--report ol, 
  .article-prose--report ul {
    margin: 1.5rem 0 !important;
    padding-right: 1.5rem !important;
    border: none;
    background: none;
  }

  .article-prose--report li {
    margin-bottom: 0.75rem !important;
    color: #a1a1aa !important;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .article-prose--report li::marker {
    color: #a855f7;
    font-weight: bold;
  }

  .article-prose--report img,
  .article-prose--report video {
    display: block;
    margin: 4rem auto !important;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.9);
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .article-prose--report img:hover {
    transform: scale(1.02);
  }

  .article-prose--report pre {
    border: 1px solid rgba(168, 85, 247, 0.1);
    background: rgba(13, 13, 18, 0.6) !important;
    backdrop-filter: blur(12px);
    border-radius: 1rem !important;
    padding: 1.5rem !important;
    margin: 2rem 0;
  }

  .article-prose--report code {
    color: #e9d5ff !important;
    font-size: 0.9em;
    background: rgba(168, 85, 247, 0.1);
    padding: 0.2rem 0.4rem;
    border-radius: 0.35rem;
  }

  .article-prose--report pre code {
    background: none;
    padding: 0;
  }
</style>
