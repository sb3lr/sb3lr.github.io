---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const tutorials = await getCollection("tutorials");
  return tutorials.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout>
  <article class="max-w-4xl mx-auto space-y-12 pb-32">
    <header class="space-y-6">
      <a href="/tutorials" class="inline-flex items-center gap-2 text-xs text-zinc-500 hover:text-cyber-purple transition-colors font-mono uppercase tracking-widest group">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        <span class="lang-ar">العودة للشروحات</span>
        <span class="lang-en">Back to Tutorials</span>
      </a>
      
      <div class="space-y-4">
        <div class="flex items-center gap-2">
           <span class="px-3 py-1 rounded-full bg-cyber-purple/10 border border-cyber-purple/20 text-[10px] text-cyber-purple font-mono uppercase">System_File</span>
           <span class="text-zinc-600 font-mono text-[10px]">/root/tutorials/{entry.slug}.md</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-black tracking-tight text-white">{entry.data.title}</h1>
        <p class="text-lg text-zinc-400 font-mono">{entry.data.description}</p>
      </div>
      
      <div class="h-[1px] w-full bg-gradient-to-r from-cyber-purple/30 via-white/5 to-transparent"></div>
    </header>

    <div class="prose prose-invert prose-cyber max-w-none 
      prose-headings:font-black prose-headings:tracking-tighter
      prose-h1:text-3xl prose-h2:text-2xl prose-h2:border-b prose-h2:border-white/5 prose-h2:pb-2
      prose-p:text-zinc-400 prose-p:leading-relaxed
      prose-code:text-cyber-blue prose-code:bg-white/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:before:content-none prose-code:after:content-none
      prose-pre:bg-zinc-950/50 prose-pre:border prose-pre:border-white/5 prose-pre:rounded-2xl prose-pre:p-6
      prose-strong:text-white prose-a:text-cyber-purple prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  /* Custom prose styles for a cyber-security look */
  .prose-cyber pre {
    position: relative;
    overflow: hidden;
  }
  .prose-cyber pre::before {
    content: "TERMINAL_OUTPUT";
    position: absolute;
    top: 0;
    right: 0;
    padding: 0.5rem 1rem;
    background: rgba(168, 85, 247, 0.1);
    border-bottom-left-radius: 1rem;
    font-family: monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    color: #a855f7;
    opacity: 0.5;
  }
</style>
