<button
    class="lang-toggle relative group px-4 py-2 rounded-xl bg-white/5 border border-white/10 hover:border-cyber-purple/50 transition-all active:scale-95 flex items-center justify-center gap-3 overflow-hidden"
>
    <!-- ... same internal content ... -->
    <div
        class="absolute inset-0 bg-gradient-to-r from-cyber-purple/10 to-cyber-blue/10 opacity-0 group-hover:opacity-100 transition-opacity"
    >
    </div>

    <span class="lang-ar text-xs font-bold text-zinc-400 group-hover:text-white"
        >EN / English</span
    >
    <span class="lang-en text-xs font-bold text-zinc-400 group-hover:text-white"
        >AR / العربية</span
    >

    <div
        class="w-8 h-8 rounded-lg bg-zinc-900 flex items-center justify-center text-sm border border-white/5 group-hover:border-cyber-purple/30"
    >
        <span class="lang-ar">🌐</span>
        <span class="lang-en">🌍</span>
    </div>
</button>

<script>
    const toggles = document.querySelectorAll(".lang-toggle");
    const html = document.documentElement;

    const updateUI = (lang: string) => {
        html.setAttribute("lang", lang);
        html.setAttribute("dir", lang === "ar" ? "rtl" : "ltr");
        localStorage.setItem("portfolio-lang", lang);
    };

    // Load saved language
    const savedLang = localStorage.getItem("portfolio-lang") || "ar";
    updateUI(savedLang);

    toggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
            const currentLang = html.getAttribute("lang");
            const newLang = currentLang === "ar" ? "en" : "ar";
            updateUI(newLang);

            // Aesthetic feedback for all toggles
            toggles.forEach((t) => {
                (t as HTMLElement).style.transform = "scale(0.95)";
                setTimeout(() => {
                    (t as HTMLElement).style.transform = "";
                }, 100);
            });
        });
    });
</script>
