---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import { SoundManager } from "../components/SoundManager";
import { AchievementManager } from "../components/AchievementManager";

const { pathname } = Astro.url;
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: "website" | "article";
  noindex?: boolean;
  keywords?: string[];
  publishedTime?: string | Date;
  modifiedTime?: string | Date;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Saeed Barran | Cybersecurity Portfolio",
  description = "Portfolio of Saeed Barran showcasing cybersecurity projects, tools, tutorials, and achievements in Arabic and English.",
  ogImage = "/profile.jpg",
  type = "website",
  noindex = false,
  keywords = [],
  publishedTime,
  modifiedTime,
  schema,
} = Astro.props;

const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = Astro.site
  ? new URL(pathname, Astro.site).toString()
  : undefined;
const ogImageUrl = new URL(ogImage, siteBase).toString();
const robots = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const keywordsContent = [
  "Saeed Barran",
  "Cybersecurity",
  "Ethical Hacking",
  "OSINT",
  "Portfolio",
  ...keywords,
].join(", ");
const publishedIso = publishedTime
  ? new Date(publishedTime).toISOString()
  : undefined;
const modifiedIso = modifiedTime ? new Date(modifiedTime).toISOString() : undefined;

const pageSchema = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "Article" : "WebPage",
  name: title,
  description,
  inLanguage: ["ar", "en"],
  ...(canonicalUrl ? { url: canonicalUrl } : {}),
  ...(publishedIso ? { datePublished: publishedIso } : {}),
  ...(modifiedIso ? { dateModified: modifiedIso } : {}),
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "0xsb3lr Portfolio",
  alternateName: "Saeed Barran Portfolio",
  inLanguage: ["ar", "en"],
  ...(Astro.site ? { url: Astro.site.toString() } : {}),
};

const additionalSchema = schema
  ? Array.isArray(schema)
    ? schema
    : [schema]
  : [];
const structuredData = [websiteSchema, pageSchema, ...additionalSchema];
---

<!DOCTYPE html>
<html lang="ar" dir="rtl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywordsContent} />
    <meta name="author" content="Saeed Barran" />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#050507" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {canonicalUrl && <link rel="alternate" hrefLang="ar" href={canonicalUrl} />}
    {canonicalUrl && <link rel="alternate" hrefLang="en" href={canonicalUrl} />}
    {canonicalUrl && (
      <link rel="alternate" hrefLang="x-default" href={canonicalUrl} />
    )}

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="0xsb3lr Portfolio" />
    <meta property="og:locale" content="ar_YE" />
    <meta property="og:locale:alternate" content="en_US" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {publishedIso && <meta property="article:published_time" content={publishedIso} />}
    {modifiedIso && <meta property="article:modified_time" content={modifiedIso} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body
    class="bg-cyber-dark text-zinc-100 min-h-screen selection:bg-cyber-purple/30 selection:text-white overflow-x-hidden"
  >
    <div class="fixed inset-0 pointer-events-none z-[9999]" id="cyber-cursor">
      <div
        class="absolute w-9 h-9 border-2 border-cyber-purple/65 bg-cyber-purple/5 rounded-full -translate-x-1/2 -translate-y-1/2 shadow-[0_0_26px_rgba(168,85,247,0.35)] [will-change:transform]"
        id="cursor-ring"
      >
      </div>
      <div
        class="absolute w-2 h-2 bg-white rounded-full -translate-x-1/2 -translate-y-1/2 shadow-[0_0_18px_rgba(255,255,255,0.9)] [will-change:transform]"
        id="cursor-dot"
      >
      </div>
    </div>

    <script>
      const ring = document.getElementById("cursor-ring") as HTMLDivElement | null;
      const dot = document.getElementById("cursor-dot") as HTMLDivElement | null;
      const desktopPointer =
        window.matchMedia("(hover: hover)").matches ||
        window.matchMedia("(pointer: fine)").matches;

      if (!desktopPointer && ring && dot) {
        ring.style.display = "none";
        dot.style.display = "none";
      }

      let targetX = 0;
      let targetY = 0;
      let ringX = 0;
      let ringY = 0;
      let rafId = 0;

      const renderCursor = () => {
        if (!ring || !dot || !desktopPointer) return;
        ringX += (targetX - ringX) * 0.14;
        ringY += (targetY - ringY) * 0.14;

        dot.style.transform = `translate3d(${targetX}px, ${targetY}px, 0) translate(-50%, -50%)`;
        ring.style.transform = `translate3d(${ringX}px, ${ringY}px, 0) translate(-50%, -50%)`;
        rafId = window.requestAnimationFrame(renderCursor);
      };

      document.addEventListener(
        "mousemove",
        (e: MouseEvent) => {
          if (!ring || !dot || !desktopPointer) return;
          targetX = e.clientX;
          targetY = e.clientY;
          dot.style.display = "block";
          ring.style.display = "block";
          if (!rafId) {
            rafId = window.requestAnimationFrame(renderCursor);
          }
        },
        { passive: true }
      );

      document.addEventListener(
        "touchstart",
        () => {
          if (ring && dot) {
            ring.style.display = "none";
            dot.style.display = "none";
          }
          if (rafId) {
            window.cancelAnimationFrame(rafId);
            rafId = 0;
          }
        },
        { passive: true }
      );
    </script>

    <SoundManager client:idle />
    <AchievementManager client:idle />

    <div
      class="layout-shell relative flex min-h-dvh w-full overflow-hidden bg-cyber-grid flex-col"
    >
      {/* Top Status Marquee Ticker */}
      <div
        class="h-6 w-full bg-black/40 border-b border-white/5 backdrop-blur-md flex items-center overflow-hidden z-[60] relative"
      >
        <div
          class="whitespace-nowrap flex animate-marquee-slower items-center gap-12 px-6"
        >
          <div
            class="flex items-center gap-2 text-[10px] text-cyber-purple/80 font-mono tracking-[0.2em] uppercase"
          >
            <span class="w-1 h-1 bg-cyber-purple rounded-full animate-ping"
            ></span>
            SYSTEM_UPTIME: 99.99% ONLINE
          </div>
          <div
            class="flex items-center gap-2 text-[10px] text-zinc-500 font-mono tracking-[0.2em] uppercase"
          >
            <span class="w-1 h-1 bg-zinc-600 rounded-full"></span>
            DEFENSE_LAYER: CLOUD_FIREWALL_LOADED
          </div>
          <div
            class="flex items-center gap-2 text-[10px] text-cyber-blue/80 font-mono tracking-[0.2em] uppercase"
          >
            <span class="w-1 h-1 bg-cyber-blue rounded-full"></span>
            ACTIVE_ENCRYPTION: AES_256_GCM
          </div>
          <div
            class="flex items-center gap-2 text-[10px] text-emerald-500/80 font-mono tracking-[0.2em] uppercase"
          >
            <span class="w-1 h-1 bg-emerald-500 rounded-full animate-pulse"
            ></span>
            0xSB3LR_VIRTUAL_OS_READY
          </div>
        </div>
      </div>

      <div class="relative flex-1 flex overflow-hidden">
        {/* Dynamic Background Glows */}
        <div
          class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-cyber-purple/20 blur-[150px] pointer-events-none animate-pulse"
        >
        </div>
        <div
          class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-cyber-blue/20 blur-[120px] pointer-events-none animate-pulse"
          style="animation-delay: 2s"
        >
        </div>

        {/* Main Content Area */}
        <main
          id="main-content"
          class="main-scroll flex-1 h-full overflow-y-auto w-full relative z-10 scrollbar-hide main-content opacity-100 pb-28 md:pb-8 pt-20 md:pt-0"
        >
          <div class="max-w-7xl mx-auto p-4 md:p-8 lg:p-16">
            <slot />
          </div>

          <div
            class="fixed inset-0 pointer-events-none bg-scanline opacity-[0.05] z-50"
          >
          </div>
        </main>

        <Sidebar />
      </div>
    </div>
  </body>
</html>
